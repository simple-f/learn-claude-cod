# 智能客服系统 - 环境变量配置
# 复制此文件为 .env 并填入实际值

# OpenAI API Key
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx

# 向量数据库路径
VECTOR_DB_PATH=./data/vector_db

# 知识库路径
KNOWLEDGE_PATH=./data/knowledge

# 日志级别 (DEBUG/INFO/WARNING/ERROR)
LOG_LEVEL=INFO

# 服务端口
WEB_PORT=8000

# Session 过期时间（秒）
SESSION_TIMEOUT=3600

# 最大上下文长度
MAX_CONTEXT_LENGTH=4000

# 流式输出延迟（毫秒）
STREAM_DELAY=100
